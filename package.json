{
  "name": "gwydion-portfolio",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "dev": "bun run i18n && vite dev --port 3000",
    "build": "bun run i18n && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxlint src --format"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.16.0",
    "@mantine/core": "^9.0.2",
    "@mantine/form": "^9.0.2",
    "@mantine/hooks": "^9.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "geist": "^1.7.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@inlang/paraglide-vite": "^1.4.0",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "oxlint": "^1.60.0",
    "postcss": "^8.5.9",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}